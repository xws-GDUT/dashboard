<view class="ec-canvas-container">
  <canvas
    wx:if="{{use2dCanvas}}"
    type="2d"
    class="ec-canvas"
    canvas-id="{{canvasId}}"
    bindtouchstart="{{ec.disableTouch ? '' : 'touchStart'}}"
    bindtouchmove="{{ec.disableTouch ? '' : 'touchMove'}}"
    bindtouchend="{{ec.disableTouch ? '' : 'touchEnd'}}"
  />
  <canvas
    wx:else
    class="ec-canvas"
    canvas-id="{{canvasId}}"
    bindtouchstart="{{ec.disableTouch ? '' : 'touchStart'}}"
    bindtouchmove="{{ec.disableTouch ? '' : 'touchMove'}}"
    bindtouchend="{{ec.disableTouch ? '' : 'touchEnd'}}"
  />
</view>
