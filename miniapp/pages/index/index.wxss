.container {
  padding: 24rpx;
  background: #f1f5f9;
  min-height: 100vh;
}

/* 状态栏 */
.status-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  font-size: 24rpx;
  color: #64748b;
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #10b981;
  display: inline-block;
  margin-right: 12rpx;
}

.refresh-btn {
  background: #2563eb;
  color: #fff;
  border: none;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

/* 卡片网格 */
.card-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  width: calc(50% - 8rpx);
  box-sizing: border-box;
  border-left: 6rpx solid #e2e8f0;
}

.card-full {
  width: 100%;
}

.card-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.card-value {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.card-sub {
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1.6;
}

/* 特定颜色 */
.gold { color: #d97706; }
.cyan { color: #06b6d4; }
.blue { color: #2563eb; }
.purple { color: #8b5cf6; }
.yellow { color: #eab308; }
.green { color: #10b981; }
.pink { color: #ec4899; }
.teal { color: #14b8a6; }
.red { color: #ef4444; }
.orange { color: #f97316; }

/* 图表 */
.chart-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.chart-title {
  font-size: 28rpx;
  color: #475569;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.chart-container {
  width: 100%;
  height: 500rpx;
}

/* 页脚 */
.footer {
  text-align: center;
  padding: 40rpx 24rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 2;
}

/* badge */
.badge {
  display: inline-block;
  padding: 2rpx 12rpx;
  border-radius: 4rpx;
  font-size: 18rpx;
  background: #fef3c7;
  color: #92400e;
  margin-left: 8rpx;
}
